{
  "manifest_version": 3,
  "name": "IndexLens",
  "description": "Elasticsearch viewer with encrypted credential storage",
  "permissions": ["storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"],
    "type": "module"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "indexlens@labanar.com",
      "strict_min_version": "109.0"
    }
  },
  "options_page": "index.html",
  "action": {
    "default_title": "IndexLens",
    "default_icon": {
      "16": "indexlens-icon-16.png",
      "32": "indexlens-icon-32.png",
      "48": "indexlens-icon-48.png"
    }
  },
  "icons": {
    "16": "indexlens-icon-16.png",
    "32": "indexlens-icon-32.png",
    "48": "indexlens-icon-48.png",
    "128": "indexlens-icon-128.png"
  }
}
